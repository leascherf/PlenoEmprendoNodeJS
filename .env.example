# ─────────────────────────────────────────────
#  PlenoEmprendo API - Variables de entorno
#  Copiá este archivo como .env y completá los valores
# ─────────────────────────────────────────────

# Servidor
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Sesión (generá un string random seguro)
SESSION_SECRET=cambia_esto_por_algo_seguro_al_menos_32_caracteres

# Google OAuth (mismos valores que tenías en appsettings.json)
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/callback
TOKEN_STORE_PATH=./.tokens

# Google Sheets - Main
SHEET_MAIN_ID=1RNrSHW6p0-p934rEcOIfGkRZgE4Qf-CqgiZvrfxBmF4
