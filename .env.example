# ─────────────────────────────────────────────
#  PlenoEmprendo - Variables de entorno
#  Copiá este archivo como .env y completá los valores
# ─────────────────────────────────────────────

# Servidor
PORT=3001
NODE_ENV=development

# Sesión (generá un string random seguro, mínimo 32 caracteres)
SESSION_SECRET=cambia_esto_por_algo_seguro_al_menos_32_caracteres

# Contraseña del panel (solo para el primer arranque — bootstrap)
# Después de que el server arranque y la seedee en la DB, podés borrar esta línea.
ADMIN_PASSWORD=la-contraseña-que-quieras

# Base de datos (MariaDB)
DB_HOST=localhost
DB_PORT=3306
DB_USER=pleno_user
DB_PASSWORD=password_segura
DB_NAME=pleno_app

# Google Service Account (path al archivo JSON de credenciales)
# Descargar desde Google Cloud Console > IAM > Service Accounts > Keys
GOOGLE_SERVICE_ACCOUNT_KEY=/ruta/al/google-sa-key.json

# Google Sheet principal (alimentado por Calendly, solo lectura)
SHEET_MAIN_ID=TU_SHEET_ID_AQUI
SHEET_MAIN_GID=0
SHEET_MAIN_HEADER_ROW=1
SHEET_MAIN_CONTACT_ID_COL=ContactId
SHEET_MAIN_PHONE_COL=RESPUESTAS
SHEET_MAIN_NAME_COL=Nombre
SHEET_MAIN_LASTNAME_COL=Apellido
SHEET_MAIN_EMAIL_COL=Mail
SHEET_MAIN_CLOSER_COL=CLOSER
SHEET_MAIN_ESTADO_COL=Estado Lead
SHEET_MAIN_DATE_COL=Agendado

# Solo para el script de migración inicial (scripts/migrateFromSheets.ts)
# Se puede borrar después de migrar
# SHEET_SECONDARY_ID=TU_SHEET_SECUNDARIO_ID
# SHEET_SECONDARY_GID=0
# SHEET_SECONDARY_HEADER_ROW=2
